# Vimersion API server — environment variables.
# Copy to .env and fill in; every variable is optional except SESSION_SECRET
# in production. Sign-in providers only appear in /api/config when BOTH of
# their variables are set.

# Port the HTTP server listens on (nginx proxies /api/ here).
PORT=3001

# Path to the SQLite database file. The Docker image sets /data/vimersion.db
# (a named volume); the default below is for local development.
DB_PATH=./vimersion.db

# The public origin players use in their browser. Used to build the OAuth
# redirect URIs and to decide whether cookies get the Secure attribute
# (https => Secure). Example production value: https://vimersion.example.com
PUBLIC_ORIGIN=http://localhost:8971

# Secret used to HMAC session tokens before they are stored. REQUIRED in
# production: if unset, a random one is generated at boot (with a warning) and
# every session dies on restart. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Google OAuth (see server/README.md for the console walkthrough).
# Redirect URI to register: ${PUBLIC_ORIGIN}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (see server/README.md for the walkthrough).
# Callback URL to register: ${PUBLIC_ORIGIN}/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
