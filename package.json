{
  "name": "vimlegends",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Learn Vim by playing — a gamified, real-editor Vim trainer.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "qa": "node scripts/qa/smoke.mjs && node scripts/qa/focus.mjs && node scripts/qa/boss.mjs && node scripts/qa/qa.mjs"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/state": "^6.7.1",
    "@codemirror/view": "^6.43.6",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@react-three/postprocessing": "^2.19.1",
    "@replit/codemirror-vim": "^6.3.0",
    "@types/three": "^0.170.0",
    "codemirror": "^6.0.2",
    "framer-motion": "^12.42.2",
    "howler": "^2.2.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "0.170.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@dicebear/collection": "^9.4.2",
    "@dicebear/core": "^9.4.3",
    "@eslint/js": "^9.39.5",
    "@tailwindcss/vite": "^4.3.2",
    "@types/howler": "^2.2.13",
    "@types/node": "^26.1.1",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.39.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "jsdom": "^29.1.1",
    "playwright": "^1.61.1",
    "prettier": "^3.9.6",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  }
}
